# OpenAI API Key (required for AI classification and recommendations)
OPENAI_API_KEY=your_openai_api_key_here

# Database URL (SQLite by default, can swap for PostgreSQL)
DATABASE_URL=sqlite:///./closetai.db

# Image upload directory
UPLOAD_DIR=./uploads

# CORS origins (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# App settings
APP_ENV=development
SECRET_KEY=your_secret_key_here
